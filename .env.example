# Set to false to use real Supabase auth + the FastAPI backend instead of mocks
VITE_USE_MOCKS=false

# FastAPI backend base URL (still used for patients/diagnoses/reports/etc.)
VITE_API_BASE_URL=/api

# Supabase project settings — Project Settings > API in your Supabase dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
